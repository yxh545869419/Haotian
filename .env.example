# SQLite/本地数据库示例；也可替换为 PostgreSQL 等 DSN
DATABASE_URL=sqlite:///./data/haotian.db

# LLM Provider 标识，例如 openai / azure_openai / anthropic
LLM_PROVIDER=openai

# OpenAI API Key：本地推荐使用标准变量名 OPENAI_API_KEY；
# 兼容旧变量名 OpenAIAPI / OPENAIAPI
OPENAI_API_KEY=your-openai-api-key

# 每日分析报告与导出文件输出目录
REPORT_DIR=./reports

# SQLite/本地数据库示例
DATABASE_URL=sqlite:///./data/haotian.db

# 临时仓库克隆目录，分析后会尝试删除；通常会成功，失败时会保留临时工作区并暴露清理状态
TMP_REPO_DIR=./data/tmp/repos

# 仓库探测边界：控制文件数、单文件字节数和证据片段数
MAX_REPO_PROBE_FILES=16
MAX_REPO_PROBE_FILE_BYTES=24000
MAX_EVIDENCE_SNIPPETS=6

# 每个深度分析批次允许处理的仓库数量；程序会自动继续后续批次
MAX_DEEP_ANALYSIS_REPOS=12

# 最终 Markdown / JSON 报告输出目录
REPORT_DIR=./data/reports

# 分阶段运行工件目录
RUN_DIR=./data/runs

# 现有 Codex skill 根目录；多个目录用分号分隔
CODEX_SKILL_ROOTS=

# Haotian 托管的新 skill 安装目录
CODEX_MANAGED_SKILL_ROOT=

# Haotian 归档 skill collection 源包的目录；不要配置为 Codex 扫描根
CODEX_COLLECTION_SKILL_ROOT=

# skill-audit-guard 的 audit_skill.py 脚本路径
SKILL_AUDIT_SCRIPT=
